{
  "name": "places-ive-been-in",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build-image-paths": "node bin/build-image-paths.js",
    "optimize-images": "bash bin/optimize-images.sh",
    "optimize-images:clean": "rm -r ./public/thumbnails && bun optimize-images",
    "dev": "vite",
    "prebuild": "bun optimize-images && bun build-image-paths",
    "build": "tsc && vite build",
    "lint": "biome check",
    "format": "biome format --write",
    "lint:styles": "stylelint './src/**/*.tsx'",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.10.8",
    "@emotion/styled": "^11.10.8",
    "@fontsource/josefin-sans": "^4.5.12",
    "mapbox-gl": "3.23.1",
    "maplibre-gl": "^2.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-map-gl": "^7.1.7",
    "react-transition-group": "^4.4.5",
    "styled-tools": "^1.7.2",
    "three": "^0.170.0",
    "vite-plugin-svgr": "^2.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/mapbox-gl": "^3.4.0",
    "@types/node": "^18.16.2",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@types/react-transition-group": "^4.4.5",
    "@types/three": "^0.170.0",
    "@untile/stylelint-config-react": "1.0.2",
    "@vitejs/plugin-react-swc": "^3.0.0",
    "postcss": "^8.4.21",
    "postcss-styled-syntax": "^0.4.0",
    "stylelint": ">=15.3",
    "typescript": "^5.0.2",
    "vite": "^4.3.0"
  }
}
